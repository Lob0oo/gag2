local GAG2_Pets = {
	"Ice Serpent", "Raccoon", "Black Dragon", "Golden Dragonfly", "Unicorn", "Monkey", "Bear", "Bee", "Robin", "Deer", "Owl", "Bunny", "Frog"
}

-- Local counter table to handle the stacking display text
local playerStacks = {}

----------------------------------------------------------------
-- REALISTIC VISUAL GENERATION LOGIC
----------------------------------------------------------------
local function spawnPerfectVisualItem(baseName, isPet)
	local searchName = isPet and baseName or (baseName .. " Seed")
	
	-- 1. Try to find the REAL game item in storage to steal its 3D model and Image
	local realGameTool = ReplicatedStorage:FindFirstChild(searchName, true) or game:GetService("Lighting"):FindFirstChild(searchName, true)
	
	-- Check if we already have this item in our inventory to handle stacking
	local currentCharacter = localPlayer.Character
	local existingInventoryItem = backpack:FindFirstChild(baseName) or (currentCharacter and currentCharacter:FindFirstChild(baseName))
	
	if existingInventoryItem then
		-- Item already exists, increase stack number and change the hotbar text
		playerStacks[baseName] = (playerStacks[baseName] or 1) + 1
		existingInventoryItem.Name = searchName .. " x" .. playerStacks[baseName]
		return
	end
	
	-- First time spawning this item in this session
	playerStacks[baseName] = 1
	local visualTool
	
	if realGameTool and realGameTool:IsA("Tool") then
		-- Excellent! We found the real model and texture from the game files. Clone it locally.
		visualTool = realGameTool:Clone()
		visualTool.Name = baseName -- Keep the identifier clean for stacking checks
	else
		-- Fallback: If the game hides assets securely, build a custom tool container
		visualTool = Instance.new("Tool")
		visualTool.Name = baseName
		visualTool.RequiresHandle = true
		
		-- Use universal fallback asset IDs for seeds and pets
		local fallbackImage = isPet and "rbxassetid://13401575222" or "rbxassetid://13401569424"
		visualTool.TextureId = fallbackImage
		
		local handle = Instance.new("Part")
		handle.Name = "Handle"
		handle.Size = Vector3.new(0.6, 0.6, 0.6)
		handle.BrickColor = isPet and BrickColor.new("Bright blue") or BrickColor.new("Bright green")
		handle.Material = Enum.Material.SmoothPlastic
		handle.Parent = visualTool
	end
	
	-- Put the textured, modeled item directly on your client hotbar
	visualTool.Parent = backpack
end


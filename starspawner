print("--- STARTING GARDEN SPAWNER ---")

local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

-- Get the player executing the script
local localPlayer = Players.LocalPlayer or Players:GetPlayers()[1]
if not localPlayer then 
    warn("No player found to spawn items near!")
    return 
end

local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
local rootPart = character:WaitForChild("HumanoidRootPart")

-- Create a visual notification in the corner of your screen so you KNOW it ran
pcall(function()
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Garden Script",
        Text = "Script Loaded Successfully!",
        Duration = 5
    })
end)

----------------------------------------------------------------
-- SETUP ASSETS (Spawns them right at your character's feet)
----------------------------------------------------------------

-- 1. Spawn Area (The seed field)
local spawnArea = Workspace:FindFirstChild("SpawnArea")
if not spawnArea then
	spawnArea = Instance.new("Part")
	spawnArea.Name = "SpawnArea"
	spawnArea.Size = Vector3.new(30, 1, 30)
	-- Spawns exactly where you are standing
	spawnArea.Position = rootPart.Position + Vector3.new(0, -2, 0)
	spawnArea.Transparency = 0.3
	spawnArea.BrickColor = BrickColor.new("Bright green")
	spawnArea.CanCollide = true
	spawnArea.Anchored = true
	spawnArea.Parent = Workspace
end

-- 2. Seed Template
local seedTemplate = ReplicatedStorage:FindFirstChild("Seed")
if not seedTemplate then
	seedTemplate = Instance.new("Model")
	seedTemplate.Name = "Seed"
	local part = Instance.new("Part")
	part.Name = "PrimaryPart"
	part.Size = Vector3.new(2, 2, 2)
	part.Shape = Enum.PartType.Ball
	part.BrickColor = BrickColor.new("Red reddish")
	part.Parent = seedTemplate
	seedTemplate.PrimaryPart = part
	seedTemplate.Parent = ReplicatedStorage
end

-- 3. Pet Template
local petTemplate = ReplicatedStorage:FindFirstChild("GardenPet")
if not petTemplate then
	petTemplate = Instance.new("Model")
	petTemplate.Name = "GardenPet"
	local part = Instance.new("Part")
	part.Name = "PrimaryPart"
	part.Size = Vector3.new(2, 2, 2)
	part.BrickColor = BrickColor.new("Deep blue")
	part.Parent = petTemplate
	petTemplate.PrimaryPart = part
	petTemplate.Parent = ReplicatedStorage
end

-- 4. Pet Spawner Pad
local petSpawner = Workspace:FindFirstChild("PetSpawner")
if not petSpawner then
	petSpawner = Instance.new("Part")
	petSpawner.Name = "PetSpawner"
	petSpawner.Size = Vector3.new(6, 0.5, 6)
	-- Spawns 10 studs in front of you
	petSpawner.Position = rootPart.Position + (rootPart.CFrame.LookVector * 10)
	petSpawner.BrickColor = BrickColor.new("Cyan")
	petSpawner.Anchored = true
	petSpawner.Parent = Workspace
end

----------------------------------------------------------------
-- LOOPS & LOGIC
----------------------------------------------------------------
local MAX_SEEDS = 10
local function getRandomPosition()
	local size = spawnArea.Size
	local pos = spawnArea.Position
	local randomX = math.random(-size.X / 2, size.X / 2)
	local randomZ = math.random(-size.Z / 2, size.Z / 2)
	return Vector3.new(pos.X + randomX, pos.Y + 2, pos.Z + randomZ)
end

-- Seed Spawner Loop
task.spawn(function()
	while true do
		local seedCount = 0
		for _, item in ipairs(Workspace:GetChildren()) do
			if item.Name == "SpawnedSeed" then seedCount = seedCount + 1 end
		end
		
		if seedCount < MAX_SEEDS then
			local newSeed = seedTemplate:Clone()
			newSeed.Name = "SpawnedSeed"
			newSeed:PivotTo(CFrame.new(getRandomPosition()))
			newSeed.Parent = Workspace
			
			newSeed.PrimaryPart.Touched:Connect(function(otherPart)
				local player = Players:GetPlayerFromCharacter(otherPart.Parent)
				if player then newSeed:Destroy() end
			end)
		end
		task.wait(2)
	end
end)

-- Pet Spawner Logic
local db = false
petSpawner.Touched:Connect(function(otherPart)
	local char = otherPart.Parent
	local player = Players:GetPlayerFromCharacter(char)
	local humRoot = char:FindFirstChild("HumanoidRootPart")
	
	if player and humRoot and not db then
		db = true
		if char:FindFirstChild(player.Name .. "s_Pet") then db = false; return end
		
		local newPet = petTemplate:Clone()
		newPet.Name = player.Name .. "s_Pet"
		local petRoot = newPet.PrimaryPart
		petRoot.CanCollide = false
		petRoot.Anchored = false
		newPet:PivotTo(humRoot.CFrame * CFrame.new(0, 5, 0))
		newPet.Parent = char
		
		local petAttachment = Instance.new("Attachment", petRoot)
		local playerAttachment = Instance.new("Attachment", humRoot)
		playerAttachment.Position = Vector3.new(2, 3, 3) 
		
		local alignPos = Instance.new("AlignPosition", petRoot)
		alignPos.MaxForce = 25000; alignPos.Responsiveness = 15
		alignPos.Attachment0 = petAttachment; alignPos.Attachment1 = playerAttachment
		
		local alignOrient = Instance.new("AlignOrientation", petRoot)
		alignOrient.MaxTorque = 25000; alignOrient.Responsiveness = 15
		alignOrient.Attachment0 = petAttachment; alignOrient.Attachment1 = playerAttachment
		
		task.wait(2)
		db = false
	end
end)

print("--- GARDEN SPAWNER LOADED ---")

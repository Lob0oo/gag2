-- Scrolling Lists Setup
local function createScroll(position)
	local scroll = Instance.new("ScrollingFrame")
	scroll.Size = UDim2.new(0, 200, 0, 250)
	scroll.Position = position
	scroll.BackgroundTransparency = 0.95
	scroll.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	scroll.BorderSizePixel = 0
	scroll.ScrollBarThickness = 2
	scroll.Parent = main
	
	local layout = Instance.new("UIListLayout", scroll)
	layout.Padding = UDim.new(0, 5)
	return scroll
end

local seedScroll = createScroll(UDim2.new(0, 15, 0, 55))
local petScroll = createScroll(UDim2.new(0, 230, 0, 55))

seedScroll.CanvasSize = UDim2.new(0, 0, 0, #GAG2_Seeds * 35)
petScroll.CanvasSize = UDim2.new(0, 0, 0, #GAG2_Pets * 35)

-- Smooth Glass Button Generator
local function createGlassButton(name, parentFrame, accentColor, clickCallback)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -6, 0, 30)
	btn.BackgroundColor3 = accentColor
	btn.BackgroundTransparency = 0.6
	btn.Text = name
	btn.TextColor3 = Color3.fromRGB(240, 240, 240)
	btn.Font = Enum.Font.SourceSansSemibold
	btn.TextSize = 14
	btn.Parent = parentFrame
	
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
	btn.MouseButton1Click:Connect(clickCallback)
end

-- Render Lists
